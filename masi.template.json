{
  "id": "appointment-hub",
  "name": "AppointmentHub",
  "description": "Sistema de agendamento para negócios de serviços — gerencie clientes, equipe, serviços e agenda em um console unificado.",
  "version": "1.0.0",
  "engine": "vite-react-gateway",
  "schemaVersion": 1,
  "migrations": ["0001_business_schema.sql"],
  "auth": {
    "provider": "better-auth",
    "roles": ["admin", "manager", "rep"]
  },
  "screens": [
    { "id": "dashboard",     "route": "/",              "title": "Painel",         "file": "src/screens/DashboardScreen" },
    { "id": "calendar",      "route": "/calendar",      "title": "Agenda",         "file": "src/screens/CalendarScreen" },
    { "id": "appointments",  "route": "/appointments",  "title": "Agendamentos",   "file": "src/screens/AppointmentsScreen" },
    { "id": "clients",       "route": "/clients",       "title": "Clientes",       "file": "src/screens/ClientsScreen" },
    { "id": "services",      "route": "/services",      "title": "Serviços",       "file": "src/screens/ServicesScreen" },
    { "id": "team",          "route": "/team",          "title": "Equipe",         "file": "src/screens/TeamScreen" }
  ],
  "editable": {
    "allow": [
      "src/screens/**",
      "src/components/**",
      "src/lib/data/*.repo.ts",
      "src/styles.css"
    ],
    "protect": [
      "src/lib/data/client.ts",
      "src/lib/data/types.gen.ts",
      "src/lib/data/preview-fixtures.ts",
      "src/lib/auth.tsx",
      "src/main.tsx",
      "src/components/RequireAuth.tsx",
      "src/components/ui/**",
      "src/lib/utils.ts",
      "vite.config.ts",
      "components.json",
      "supabase/migrations/**"
    ]
  },
  "composio": {
    "toolkits": []
  },
  "envContract": ["VITE_GATEWAY_URL"]
}
